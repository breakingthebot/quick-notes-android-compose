<?xml version="1.0" encoding="utf-8"?>
<!--
  Provides a simple launcher preview for the Quick Notes home-screen widget.
  Connects to: quick_notes_widget_info.xml and the widget picker UI.
  Created: 2026-07-04
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4EFE7"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_title"
        android:textColor="#7A4B2E"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="3 active notes"
        android:textColor="#5E5148"
        android:textSize="12sp" />
</LinearLayout>
